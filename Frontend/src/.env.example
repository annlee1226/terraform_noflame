# =============================================================================
# Frontend Environment Variables
# Copy this to .env for local development or production builds
# =============================================================================

# Backend API URL
# - For local development: http://localhost:5000 (default if not set)
# - For production: http://YOUR_EC2_IP:5000 or https://your-domain.com
VITE_API_URL=http://localhost:5000

# Google Maps API Key (optional - defaults to key in code)
# VITE_GOOGLE_MAPS_API_KEY=your_key_here
